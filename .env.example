# =============================
# Addy Core
# =============================
APP_ENV=development
APP_NAME=Addy
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
BOT_NAME=Addy
LOG_LEVEL=INFO
LOG_JSON=false

# =============================
# Security / Auth
# =============================
JWT_SECRET=replace-me-with-64-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# =============================
# Database / Cache / Queue
# =============================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/addy
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/addy
REDIS_URL=redis://localhost:6379/0

# =============================
# Discord
# =============================
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback
DISCORD_PERMISSIONS=8
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_BOT_INVITE_SCOPES=bot applications.commands
DISCORD_BOT_INVITE_URL=
DISCORD_OWNER_IDS=123456789012345678,987654321098765432

# =============================
# AI
# =============================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_MODERATION_MODEL=omni-moderation-latest
AI_REQUEST_TIMEOUT=30

# =============================
# Billing / Monetization
# =============================
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
TRIAL_DAYS=7
DEFAULT_PREMIUM_DAYS=30
PREMIUM_GRACE_DAYS=2

# =============================
# Feature Toggles
# =============================
ENABLE_ANALYTICS=true
ENABLE_WORKERS=true
ENABLE_TRIALS=true
ENABLE_OFFERS=true
ENABLE_PROMO_CODES=true
ENABLE_RATE_LIMITING=true

# =============================
# Workers
# =============================
WORKER_POLL_SECONDS=15
YOUTUBE_POLL_SECONDS=120
ANALYTICS_POLL_SECONDS=300
TRIAL_EXPIRY_POLL_SECONDS=600
PREMIUM_EXPIRY_POLL_SECONDS=600

# =============================
# Dashboard (Next.js)
# =============================
NEXT_PUBLIC_APP_NAME=Addy
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_DISCORD_CLIENT_ID=
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/login/callback
NEXT_PUBLIC_BOT_INVITE_URL=

# =============================
# S3 / Storage (optional)
# =============================
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# =============================
# Observability
# =============================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
